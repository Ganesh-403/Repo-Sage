# ─── RepoSage Environment Variables ───
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Required: Ollama configuration for local LLM and Embeddings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Optional: GitHub Personal Access Token for indexing private repositories
# Generate at: https://github.com/settings/tokens (requires 'repo' scope)
GITHUB_TOKEN=

# Optional: Override defaults
# CHROMA_PERSIST_DIR=./chroma_db
# BACKEND_PORT=8000
# FRONTEND_PORT=8501
