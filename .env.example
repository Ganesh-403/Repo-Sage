# ─── RepoSage Environment Variables ───
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Required: Ollama configuration for local LLM and Embeddings
# Defaults to http://localhost:11434 (use http://host.docker.internal:11434 in Docker on Windows/macOS)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Optional: Toggle query expansion logic
# Set to 'false' (default) to bypass LLM query expansion for near-instant search retrieval,
# which is recommended for local deployments. Set to 'true' to enable multi-query expansion.
ENABLE_QUERY_EXPANSION=false

# Optional: GitHub Personal Access Token for indexing private repositories
# Generate at: https://github.com/settings/tokens (requires 'repo' scope)
# GITHUB_TOKEN=your_pat_here

# Optional: Directory overrides
# Local default: ./chroma_db
# Docker compose mapping: /app/chroma_db
CHROMA_PERSIST_DIR=./chroma_db

# Optional: Port overrides
# BACKEND_PORT=8000
# FRONTEND_PORT=5173
